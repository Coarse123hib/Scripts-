-- Модуль тотального Wallhack (Все игроки, боты, сущности)
local WH_Elements = {}

local function ClearWH()
    for _, obj in pairs(WH_Elements) do
        if obj then obj:Destroy() end
    end
    table.clear(WH_Elements)
end

local function ConstructWH(character, color)
    if character:FindFirstChild("MornWH") then return end
    local Box = Instance.new("BoxHandleAdornment")
    Box.Name = "MornWH"
    Box.Size = character:GetExtentsSize() + Vector3.new(0.1, 0.1, 0.1)
    Box.AlwaysOnTop = true
    Box.ZIndex = 5
    Box.Adornee = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
    Box.Color3 = color
    Box.Transparency = 0.6
    Box.Parent = game:GetService("CoreGui")
    table.insert(WH_Elements, Box)
end

task.spawn(function()
    while task.wait(1.5) do
        if State.WallhackAll then
            ClearWH()
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("Humanoid") and obj.Parent and obj.Parent ~= LocalPlayer.Character then
                    local root = obj.Parent:FindFirstChild("HumanoidRootPart") or obj.Parent.PrimaryPart
                    if root then
                        local charName = obj.Parent.Name:lower()
                        local isPiggy = false
                        
                        if charName:find("piggy") or obj.Parent:GetAttribute("IsPiggy") == true or Players:GetPlayerFromCharacter(obj.Parent) == nil then
                            isPiggy = true
                        end
                        
                        local targetColor = isPiggy and Color3.fromRGB(255, 40, 40) or Color3.fromRGB(40, 255, 40)
                        ConstructWH(obj.Parent, targetColor)
                    end
                end
            end
        end
    end
end)

CreateToggle(Pages.ESP, "Wallhack (All & Bots)", function(val)
    State.WallhackAll = val
    if not val then ClearWH() end
end)

