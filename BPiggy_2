-- Функция очистки хэшей и идентификаторов из названий
local function CleanItemName(rawName)
    local clean = rawName:gsub("^[-%d]+", "") -- Удаление ведущих цифр и дефисов
    clean = clean:gsub("[-%d]+$", "") -- Удаление хвостовых цифр
    clean = clean:gsub("Token%d+", "Token")
    clean = clean:gsub("Key%d+", "Key")
    if clean == "" or clean == " " then clean = rawName end -- Фоллбэк
    return clean
end

local function ScanMapItems()
    for _, child in pairs(ItemDropdownFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local itemsFound = {}
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") or (obj:IsA("ClickDetector") and obj.Parent) then
            local rawName = obj:IsA("Tool") and obj.Name or obj.Parent.Name
            local cleanName = CleanItemName(rawName)
            
            if not itemsFound[cleanName] then
                itemsFound[cleanName] = obj:IsA("Tool") and obj or obj.Parent
                
                local ItemButton = Instance.new("TextButton")
                ItemButton.Size = UDim2.new(1, -8, 0, 32)
                ItemButton.BackgroundColor3 = Color_Background
                ItemButton.Text = "  " .. cleanName
                ItemButton.TextColor3 = Color_TextLight
                ItemButton.Font = Enum.Font.SourceSans
                ItemButton.TextSize = 15
                ItemButton.TextXAlignment = Enum.TextXAlignment.Left
                ItemButton.Parent = ItemDropdownFrame
                
                local IBS = Instance.new("UIStroke")
                IBS.Color = Color3.fromRGB(40, 40, 45)
                IBS.Parent = ItemButton

                ItemButton.MouseButton1Click:Connect(function()
                    SelectedItem = cleanName
                    TargetItemInstance = itemsFound[cleanName]
                    ActionButton.Text = "Получить: " .. cleanName
                end)
            end
        end
    end
    ItemDropdownFrame.CanvasSize = UDim2.new(0, 0, 0, ItemLayout.AbsoluteContentSize.Y)
end

Pages.Items:GetPropertyChangedSignal("Visible"):Connect(function()
    if Pages.Items.Visible then ScanMapItems() end
