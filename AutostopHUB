local function teleportToPiggy()
    local piggyChar = nil
    -- Поиск главного Piggy (модель с именем "Piggy")
    for _, model in ipairs(workspace:GetDescendants()) do
        if model:IsA("Model") and model.Name == PIGGY_NAME then
            piggyChar = model
            break
        end
    end
    if not piggyChar then
        -- Попытка найти игрока с персонажем-пигги
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character.Name == PIGGY_NAME then
                piggyChar = plr.Character
                break
            end
        end
    end
    if piggyChar and piggyChar:FindFirstChild("HumanoidRootPart") then
        local root = piggyChar.HumanoidRootPart
        local lookVec = root.CFrame.LookVector
        local targetPos = root.Position - lookVec * trDistance
        character:MoveTo(targetPos)
    end
end

