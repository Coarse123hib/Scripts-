-- Функция выдачи предметов (Безопасное принудительное добавление)
local function giveItem(itemName)
    local tool = Instance.new("Tool")
    tool.Name = itemName
    tool.RequiresHandle = true
    
    local handle = Instance.new("Part")
    handle.Name = "Handle"
    handle.Size = Vector3.new(1, 1, 2)
    handle.Transparency = 0.5 -- Слегка прозрачный, чтобы точно увидеть появление
    handle.Parent = tool
    
    tool.Parent = LocalPlayer.Backpack
end

HammerBtn.MouseButton1Click:Connect(function() giveItem("Hammer") end)
GunBtn.MouseButton1Click:Connect(function() giveItem("Gun") end)

-- Переключатель работы ESP
ESPToggle.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    if espEnabled then
        ESPToggle.Text = "ESP (Chams): ON"
        ESPToggle.BackgroundColor3 = Color3.fromRGB(140, 50, 230)
        
        -- Поиск всех игроков
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character then applyESP(p.Character) end
            p.CharacterAdded:Connect(applyESP)
        end
        -- Поиск ботов на карте
        for _, obj in pairs(workspace:GetChildren()) do
            applyESP(obj)
        end
        workspace.ChildAdded:Connect(applyESP)
    else
        ESPToggle.Text = "ESP (Chams): OFF"
        ESPToggle.BackgroundColor3 = Color3.fromRGB(150, 40, 40)
        removeESP()
    end
end)
