-- ФУНКЦИЯ ДЛЯ ПЕРЕТАСКИВАНИЯ (Универсальная для круглого и квадратного меню)
local function makeDraggable(frame, target)
    target = target or frame
    local dragging, dragInput, dragStart, startPos

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ОПРЕДЕЛЕНИЕ РОЛИ ДЛЯ ESP (Красный - Пигги/Бот, Зеленый - Игрок)
local function getESPColor(playerOrModel)
    if playerOrModel:IsA("Player") then
        local isPiggy = playerOrModel:GetAttribute("IsPiggy") or playerOrModel.Team == game.Teams:FindFirstChild("Piggy")
        if isPiggy then
            return Color3.fromRGB(255, 30, 30) -- Красный для Пигги-Игрока
        else
            return Color3.fromRGB(30, 255, 30) -- Зеленый для Выжившего
        end
    else
        -- Если это бот (на картах Piggy они обычно NPC модели)
        if playerOrModel.Name:lower():find("piggy") or playerOrModel:FindFirstChild("Piggy") or playerOrModel:GetAttribute("Bot") then
            return Color3.fromRGB(255, 30, 30) -- Красный для Бота Пигги
        end
    end
    return Color3.fromRGB(30, 255, 30)
end

-- ЛОГИКА ESP (CHAMS)
local function applyESP(object)
    if not espEnabled then return end
    if object:FindFirstChild("ESPHighlight") then return end
    
    local isCharacter = false
    local targetColor = Color3.fromRGB(30, 255, 30)

    if Players:GetPlayerFromCharacter(object) then
        isCharacter = true
        targetColor = getESPColor(Players:GetPlayerFromCharacter(object))
    elseif object.Name:lower():find("piggy") or object:findFirstChild("Humanoid") then
        isCharacter = true
        targetColor = getESPColor(object)
    end

    if isCharacter and object ~= LocalPlayer.Character then
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESPHighlight"
        highlight.FillColor = targetColor
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.35
        highlight.OutlineTransparency = 0.1
        highlight.Adornee = object
        highlight.Parent = object
        table.insert(highlights, highlight)
    end
end

local function removeESP()
    for _, highlight in pairs(highlights) do
        if highlight and highlight.Parent then
            highlight:Destroy()
        end
    end
    table.clear(highlights)
end

