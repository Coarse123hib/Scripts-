-- === ФУНКЦИОНАЛ (без Debris, прямое удаление) ===
local espObjects = {}
local lockObjects = {}
local heightObjects = {}

RunService.RenderStepped:Connect(function()
    -- Очистка старых ESP
    for _, v in ipairs(espObjects) do v:Destroy() end
    espObjects = {}
    for _, v in ipairs(lockObjects) do v:Destroy() end
    lockObjects = {}
    for _, v in ipairs(heightObjects) do v:Destroy() end
    heightObjects = {}

    -- ESP PLAYER
    if getEsp() then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local box = Instance.new("BoxHandleAdornment")
                box.Size = Vector3.new(3,5,1.5)
                box.Adornee = plr.Character.HumanoidRootPart
                box.Color3 = Color3.fromRGB(0,0,255)
                box.Transparency = 0.5
                box.ZIndex = 0
                box.Parent = plr.Character
                table.insert(espObjects, box)
            end
        end
    end

    -- ESP LOCK
    if getLock() then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local bill = Instance.new("BillboardGui")
                bill.Size = UDim2.new(0,100,0,30)
                bill.Adornee = plr.Character.HumanoidRootPart
                bill.AlwaysOnTop = true
                local lbl = Instance.new("TextLabel", bill)
                lbl.Size = UDim2.new(1,0,1,0)
                lbl.BackgroundTransparency = 1
                lbl.Text = "⏳ " .. math.floor(os.time()%60) .. "s"
                lbl.TextColor3 = Color3.fromRGB(255,200,0)
                lbl.Font = Enum.Font.Legacy
                lbl.TextScaled = true
                bill.Parent = plr.Character
                table.insert(lockObjects, bill)
            end
        end
    end

    -- ESP HEIGHT BRAINROT
    if getHeight() then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and string.find(obj.Name, "Brainrot") then
                local box = Instance.new("BoxHandleAdornment")
                box.Size = obj.Size
                box.Adornee = obj
                box.Color3 = Color3.fromRGB(255,0,200)
                box.Transparency = 0.3
                box.Parent = obj
                table.insert(heightObjects, box)
                
                local bill = Instance.new("BillboardGui")
                bill.Size = UDim2.new(0,150,0,40)
                bill.Adornee = obj
                bill.AlwaysOnTop = true
                local lbl = Instance.new("TextLabel", bill)
                lbl.Size = UDim2.new(1,0,1,0)
                lbl.BackgroundTransparency = 1
                lbl.Text = obj.Name .. "\n+5.2/s"
                lbl.TextColor3 = Color3.fromRGB(0,255,150)
                lbl.Font = Enum.Font.Legacy
                lbl.TextScaled = true
                bill.Parent = obj
                table.insert(heightObjects, bill)
            end
        end
    end

    -- INFINITY JUMP
    if getInfJump() then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
            char.Humanoid.JumpPower = 50
        end
    end

    -- JUMP BOOST
    if getJumpBoost() then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.JumpPower = jumpPower
        end
    end

    -- SPEEDBOOST
    if getSpeedBoost() then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = walkSpeed
        end
    end

    -- AUTOWEB
    if getWeb() then
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool and tool.Name == "Web Slinger" then
            local nearest = nil
            local minDist = math.huge
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (plr.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = plr.Character.HumanoidRootPart
                    end
                end
            end
            if nearest then
                tool:Activate()
                tool.Handle.CFrame = CFrame.new(tool.Handle.Position, nearest.Position)
            end
        end
    end
end)

-- AUTOGRAB (зажим E)
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.E and getGrab() then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") and string.find(obj.Name, "Brainrot") and (obj.Position - char.HumanoidRootPart.Position).Magnitude < 10 then
                    obj:Destroy()
                end
            end
        end
    end
end)

