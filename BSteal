-- Функция создания тогла с состоянием
local function makeToggle(parent, text, yPos, default)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, 0, 0, 35)
    frame.Position = UDim2.new(0, 0, 0, yPos)
    frame.BackgroundTransparency = 1

    local label = makeLabel(text, frame, UDim2.new(0.7,0,1,0), UDim2.new(0,0,0,0), Color3.fromRGB(220,220,255))
    label.TextXAlignment = Enum.TextXAlignment.Left

    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0, 80, 1, -6)
    btn.Position = UDim2.new(0.7, 0, 0, 3)
    btn.BackgroundColor3 = default and Color3.fromRGB(0,200,0) or Color3.fromRGB(100,100,100)
    btn.Text = default and "ON" or "OFF"
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.Legacy
    btn.TextScaled = true
    local c = Instance.new("UICorner", btn)
    c.CornerRadius = UDim.new(0, 4)

    local state = default or false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.BackgroundColor3 = state and Color3.fromRGB(0,200,0) or Color3.fromRGB(100,100,100)
        btn.Text = state and "ON" or "OFF"
    end)
    return btn, function() return state end
end

