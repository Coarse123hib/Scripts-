-- AUTOWEB (автоаим на Web Slinger)
RunService.RenderStepped:Connect(function()
    if getWeb() then
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool and tool.Name == "Web Slinger" then
            local nearest = nil
            local minDist = math.huge
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (plr.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = plr.Character.HumanoidRootPart
                    end
                end
            end
            if nearest then
                tool:Activate()
                tool.Handle.CFrame = CFrame.new(tool.Handle.Position, nearest.Position)
            end
        end
    end
end)

-- AUTOGRAB (зажим E)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if getGrab() and input.KeyCode == Enum.KeyCode.E then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") and obj.Name:find("Brainrot") and (obj.Position - char.HumanoidRootPart.Position).Magnitude < 10 then
                    -- Имитация грабежа
                    obj:Destroy()
                end
            end
        end
    end
end)

