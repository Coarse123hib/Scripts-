-- Логика выдачи предметов (Hammer / Gun)
local function giveItem(itemName)
    -- Ищет предмет в модулях игры или ящиках карты Piggy (базовый триггер)
    local tools = game:GetService("ReplicatedStorage"):FindFirstChild("Tools") or game:GetService("Storage")
    local item = tools and tools:FindFirstChild(itemName)
    
    if item then
        local clone = item:Clone()
        clone.Parent = LocalPlayer.Backpack
    else
        -- Альтернативный поиск по всей игре, если папка скрыта
        for _, obj in pairs(game:GetDescendants()) do
            if obj:IsA("Tool") and obj.Name:lower() == itemName:lower() then
                local clone = obj:Clone()
                clone.Parent = LocalPlayer.Backpack
                break
            end
        end
    end
end

HammerBtn.MouseButton1Click:Connect(function()
    giveItem("Hammer")
end)

GunBtn.MouseButton1Click:Connect(function()
    giveItem("Gun")
end)

-- Логика переключения ESP (Фиолетовые Chams)
ESPToggle.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    if espEnabled then
        ESPToggle.Text = "ESP: ON"
        ESPToggle.BackgroundColor3 = Color3.fromRGB(138, 43, 226) -- Фиолетовая кнопка активна
        for _, player in pairs(Players:GetPlayers()) do
            checkAndApplyESP(player)
        end
    else
        ESPToggle.Text = "ESP: OFF"
        ESPToggle.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
        removeESP()
    end
end)

Players.PlayerAdded:Connect(function(player)
    if espEnabled then
        checkAndApplyESP(player)
    end
end)

