-- ФУНКЦИЯ ОБНОВЛЕНИЯ ESP (CHAMS)
local function applyESP(character, isPiggy)
    if not espEnabled then return end
    if character:FindFirstChild("ESPHighlight") then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESPHighlight"
    highlight.FillColor = Color3.fromRGB(138, 43, 226) -- Фиолетовый цвет
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0.1
    highlight.Adornee = character
    highlight.Parent = character
    table.insert(highlights, highlight)
end

local function removeESP()
    for _, highlight in pairs(highlights) do
        if highlight and highlight.Parent then
            highlight:Destroy()
        end
    end
    table.clear(highlights)
end

local function checkAndApplyESP(player)
    if player == LocalPlayer then return end
    if player.Character then
        local isPiggy = player:GetAttribute("IsPiggy") or player.Team == game.Teams:FindFirstChild("Piggy")
        applyESP(player.Character, isPiggy)
    end
    player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        local isPiggy = player:GetAttribute("IsPiggy") or player.Team == game.Teams:FindFirstChild("Piggy")
        applyESP(char, isPiggy)
    end)
end

