local function ScanMapItems()
    for _, child in pairs(ItemDropdownFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local itemsFound = {}
    
    -- Сканирование Workspace на наличие Tools / Предметов
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") or (obj:IsA("ClickDetector") and obj.Parent and not itemsFound[obj.Parent.Name]) then
            local targetName = obj:IsA("Tool") and obj.Name or obj.Parent.Name
            if not itemsFound[targetName] then
                itemsFound[targetName] = obj
                
                local ItemButton = Instance.new("TextButton")
                ItemButton.Size = UDim2.new(1, -10, 0, 30)
                ItemButton.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
                ItemButton.Text = targetName
                ItemButton.TextColor3 = Color3.fromRGB(220, 220, 220)
                ItemButton.Font = Enum.Font.SourceSans
                ItemButton.TextSize = 16
                ItemButton.Parent = ItemDropdownFrame
                
                ItemButton.MouseButton1Click:Connect(function()
                    SelectedItem = targetName
                    WSLabel.Text = "Выбран: " .. SelectedItem -- Временный вывод информации
                end)
            end
        end
    end
    ItemDropdownFrame.CanvasSize = UDim2.new(0, 0, 0, ItemLayout.AbsoluteContentSize.Y)
end

