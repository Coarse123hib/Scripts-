-- Раздел 1: ESP
local ESPElements = {}

local function ApplyESP(object, color)
    if not object:FindFirstChild("MornESP") then
        local Highlight = Instance.new("Highlight")
        Highlight.Name = "MornESP"
        Highlight.FillColor = color
        Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        Highlight.FillTransparency = 0.5
        Highlight.OutlineTransparency = 0
        Highlight.Adornee = object
        Highlight.Parent = object
        table.insert(ESPElements, Highlight)
    end
end

local function ClearESP()
    for i = #ESPElements, 1, -1 do
        if ESPElements[i] then
            ESPElements[i]:Destroy()
        end
        table.remove(ESPElements, i)
    end
end

RunService.RenderStepped:Connect(function()
    if not State.ESPPiggy and not State.ESPSurvivals then return end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local isPiggy = false
            
            -- Проверка на то, является ли игрок Piggy
            if p.Character:FindFirstChild("Piggy") or p:GetAttribute("IsPiggy") == true or Workspace:FindFirstChild("Piggy") == p.Character then
                isPiggy = true
            end
            
            -- Дополнительная проверка по специфическим моделям ботов Piggy в Workspace
            for _, obj in pairs(Workspace:GetChildren()) do
                if obj:IsA("Model") and (obj.Name == "Piggy" or obj:FindFirstChild("Piggy")) then
                    ApplyESP(obj, Color3.fromRGB(255, 0, 0))
                end
            end

            if isPiggy and State.ESPPiggy then
                ApplyESP(p.Character, Color3.fromRGB(255, 0, 0))
            elseif not isPiggy and State.ESPSurvivals then
                ApplyESP(p.Character, Color3.fromRGB(0, 255, 0))
            end
        end
    end
end)

CreateToggle(Pages.ESP, "ESP Piggy", function(val)
    State.ESPPiggy = val
    if not val then ClearESP() end
end)

CreateToggle(Pages.ESP, "ESP Survivals", function(val)
    State.ESPSurvivals = val
    if not val then ClearESP() end
end)


