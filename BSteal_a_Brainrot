local function CreateTab(name)
    local panel = create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        CanvasSize = UDim2.new(0, 0, 2, 0),
        ScrollBarThickness = 2,
        Visible = false,
        Parent = ContentContainer
    })
    local layout = create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8), Parent = panel })
    
    local button = create("TextButton", {
        Size = UDim2.new(1, -10, 0, 35),
        BackgroundColor3 = Color3.fromRGB(25, 25, 25),
        Text = name,
        TextColor3 = Color3.fromRGB(200, 200, 200),
        Font = PIXEL_FONT,
        TextSize = 14,
        Parent = TabButtons
    })
    create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = button })
    
    button.MouseButton1Click:Connect(function()
        for _, p in pairs(TabPanels) do p.Visible = false end
        for _, b in pairs(Tabs) do b.TextColor3 = Color3.fromRGB(200, 200, 200) b.BackgroundColor3 = Color3.fromRGB(25, 25, 25) end
        panel.Visible = true
        button.TextColor3 = Color3.fromRGB(0, 170, 255)
        button.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    end)
    
    table.insert(Tabs, button)
    table.insert(TabPanels, panel)
    return panel
end

