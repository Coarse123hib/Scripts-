-- Очистка ESP
local function clearESP()
    for _, v in pairs(ESP_Cache.Players) do if v then v:Destroy() end end
    for _, v in pairs(ESP_Cache.Bases) do if v then v:Destroy() end end
    if ESP_Cache.Brainrot then ESP_Cache.Brainrot:Destroy() ESP_Cache.Brainrot = nil end
    ESP_Cache.Players = {}
    ESP_Cache.Bases = {}
end

