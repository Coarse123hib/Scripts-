-- Шаблон UI элемента: Переключатель (Toggle)
local function AddToggle(parent, text, stateKey, callback)
    local frame = create("Frame", { Size = UDim2.new(1, -10, 0, 40), BackgroundColor3 = Color3.fromRGB(22, 22, 22), Parent = parent })
    create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = frame })
    
    local label = create("TextLabel", {
        Size = UDim2.new(0.7, 0, 1, 0), Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1, Text = text, TextColor3 = Color3.fromRGB(230, 230, 230),
        Font = PIXEL_FONT, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, Parent = frame
    })
    
    local switch = create("TextButton", {
        Size = UDim2.new(0, 45, 0, 22), Position = UDim2.new(1, -55, 0.5, -11),
        BackgroundColor3 = State[stateKey] and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(40, 40, 40),
        Text = "", Parent = frame
    })
    create("UICorner", { CornerRadius = UDim.new(0, 11), Parent = switch })
    
    switch.MouseButton1Click:Connect(function()
        State[stateKey] = not State[stateKey]
        switch.BackgroundColor3 = State[stateKey] and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(40, 40, 40)
        if callback then callback(State[stateKey]) end
    end)
end

-- Шаблон UI элемента: Поле ввода (Input)
local function AddInput(parent, labelText, defaultValue, min, max, callback)
    local frame = create("Frame", { Size = UDim2.new(1, -10, 0, 40), BackgroundColor3 = Color3.fromRGB(22, 22, 22), Parent = parent })
    create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = frame })
    
    local label = create("TextLabel", {
        Size = UDim2.new(0.6, 0, 1, 0), Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1, Text = labelText, TextColor3 = Color3.fromRGB(18, 180, 180),
        Font = PIXEL_FONT, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, Parent = frame
    })
    
    local input = create("TextBox", {
        Size = UDim2.new(0, 70, 0, 26), Position = UDim2.new(1, -80, 0.5, -13),
        BackgroundColor3 = Color3.fromRGB(30, 30, 30), Text = tostring(defaultValue),
        TextColor3 = Color3.fromRGB(255, 255, 255), Font = PIXEL_FONT, TextSize = 14, Parent = frame
    })
    create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = input })
    
    input.FocusLost:Connect(function()
        local val = tonumber(input.Text)
        if val then
            val = math.clamp(val, min, max)
            input.Text = tostring(val)
            callback(val)
        else
            input.Text = tostring(defaultValue)
        end
    end)
end

