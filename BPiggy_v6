-- ВЫДАЧА ПРЕДМЕТОВ С КАРТЫ ПО ИМЕНИ
local function giveOriginalItem(itemName)
    local originalTool = nil
    
    local searchContainers = {game:GetService("ReplicatedStorage"), game:GetService("Lighting")}
    for _, container in pairs(searchContainers) do
        local found = container:FindFirstChild(itemName, true)
        if found and found:IsA("Tool") then
            originalTool = found
            break
        end
    end
    
    if not originalTool then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Tool") and obj.Name:lower() == itemName:lower() then
                originalTool = obj
                break
            end
        end
    end
    
    if originalTool then
        local clone = originalTool:Clone()
        clone.Parent = LocalPlayer.Backpack
    else
        local tool = Instance.new("Tool")
        tool.Name = itemName
        local handle = Instance.new("Part")
        handle.Name = "Handle"
        handle.Size = Vector3.new(1, 1, 2)
        handle.Parent = tool
        tool.Parent = LocalPlayer.Backpack
    end
end

