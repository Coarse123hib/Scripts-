-- ФУНКЦИЯ ДЛЯ ПЕРЕТАСКИВАНИЯ
local function makeDraggable(frame, target)
    target = target or frame
    local dragging, dragInput, dragStart, startPos

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ОПРЕДЕЛЕНИЕ РОЛИ ДЛЯ ESP
local function getESPColor(object)
    if object:IsA("Model") then
        local pl = Players:GetPlayerFromCharacter(object)
        if pl then
            local isPiggy = pl:GetAttribute("IsPiggy") or pl.Team == game.Teams:FindFirstChild("Piggy")
            if isPiggy then
                return Color3.fromRGB(255, 30, 30)
            else
                return Color3.fromRGB(30, 255, 30)
            end
        else
            local nameLower = object.Name:lower()
            if nameLower:find("piggy") or nameLower:find("bot") or nameLower:find("npc") or object:GetAttribute("Bot") then
                return Color3.fromRGB(255, 30, 30)
            end
        end
    end
    return Color3.fromRGB(30, 255, 30)
end

-- ЛОГИКА ESP (CHAMS)
local function applyESP(object)
    if not espEnabled then return end
    if not object:IsA("Model") or object:FindFirstChild("ESPHighlight") then return end
    if object == LocalPlayer.Character then return end

    local isTarget = false
    if Players:GetPlayerFromCharacter(object) or object:FindFirstChildOfClass("Humanoid") then
        isTarget = true
    end

    if isTarget then
        local targetColor = getESPColor(object)
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESPHighlight"
        highlight.FillColor = targetColor
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.35
        highlight.OutlineTransparency = 0.1
        highlight.Adornee = object
        highlight.Parent = object
        table.insert(highlights, highlight)
    end
end

local function removeESP()
    for _, highlight in pairs(highlights) do
        if highlight and highlight.Parent then
            highlight:Destroy()
        end
    end
    table.clear(highlights)
end

local function scanMapForESP()
    if not espEnabled then return end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character then applyESP(p.Character) end
    end
    for _, desc in pairs(workspace:GetDescendants()) do
        if desc:IsA("Model") then
            applyESP(desc)
        end
    end
end

-- ЛОГИКА ESP ITEMS
local function applyItemESP(object)
    if not espItemsEnabled then return end
    if not object:IsA("Tool") or object:FindFirstChild("ItemESPHighlight") then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "ItemESPHighlight"
    highlight.FillColor = Color3.fromRGB(255, 215, 0) -- Золотистый цвет для предметов
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0.1
    highlight.Adornee = object
    highlight.Parent = object
    table.insert(itemHighlights, highlight)
end

local function removeItemESP()
    for _, highlight in pairs(itemHighlights) do
        if highlight and highlight.Parent then
            highlight:Destroy()
        end
    end
    table.clear(itemHighlights)
end

local function scanMapForItemESP()
    if not espItemsEnabled then return end
    for _, desc in pairs(workspace:GetDescendants()) do
        if desc:IsA("Tool") then
            applyItemESP(desc)
        end
    end
end

