end)

-- Функция поиска самого прибыльного Brainrot на карте
local function FindHighestBrainrot()
    local highestValue = -1
    local targetObject = nil
    local incomePerSecond = 0
    local bName = "Unknown"

    -- Поиск объектов в Workspace (обычно Brainrots лежат в выделенной папке или прямо на карте)
    local itemsContainer = Workspace:FindFirstChild("DroppedItems") or Workspace:FindFirstChild("Brainrots") or Workspace
    for _, item in pairs(itemsContainer:GetChildren()) do
        if item:IsA("Model") or item:IsA("BasePart") then
            -- Чтение параметров ценности из атрибутов или внутренних значений
            local valueAttr = item:GetAttribute("Income") or item:GetAttribute("Value") or item:GetAttribute("Price")
            local valueValue = item:FindFirstChild("Income") or item:FindFirstChild("Value")
            
            local currentVal = 0
            if valueAttr then currentVal = tonumber(valueAttr)
            elseif valueValue and valueValue:IsA("ValueBase") then currentVal = tonumber(valueValue.Value) end
            
            if currentVal and currentVal > highestValue and item:SetPrimaryPartCFrame() or item:IsA("BasePart") then
                highestValue = currentVal
                targetObject = item
                incomePerSecond = currentVal
                bName = item.Name
            end
        end
    end
    return targetObject, bName, incomePerSecond
end

