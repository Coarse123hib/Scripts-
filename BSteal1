local function createRow(parent, name, hasSlider, minV, maxV, defV, toggleCallback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -10, 0, 55)
    row.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    row.Parent = parent
    
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.48, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = name
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.TextScaled = true
    lbl.Font = Enum.Font.Code
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = row
    
    local tog = Instance.new("TextButton")
    tog.Size = UDim2.new(0.22, 0, 0.65, 0)
    tog.Position = UDim2.new(0.52, 0, 0.2, 0)
    tog.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    tog.Text = "OFF"
    tog.TextColor3 = Color3.new(1,1,1)
    tog.TextScaled = true
    tog.Font = Enum.Font.Code
    tog.Parent = row
    Instance.new("UICorner", tog)
    
    local valLabel
    local sliderFrame
    local sliderBar
    
    if hasSlider then
        sliderFrame = Instance.new("Frame")
        sliderFrame.Size = UDim2.new(0.22, 0, 0.45, 0)
        sliderFrame.Position = UDim2.new(0.76, 0, 0.3, 0)
        sliderFrame.BackgroundColor3 = Color3.fromRGB(60,60,60)
        sliderFrame.Parent = row
        Instance.new("UICorner", sliderFrame)
        
        sliderBar = Instance.new("Frame")
        sliderBar.Size = UDim2.new(0.6, 0, 1, 0)
        sliderBar.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        sliderBar.Parent = sliderFrame
        Instance.new("UICorner", sliderBar)
        
        valLabel = Instance.new("TextLabel")
        valLabel.Size = UDim2.new(0.18, 0, 1, 0)
        valLabel.Position = UDim2.new(1.05, 0, 0, 0)
        valLabel.BackgroundTransparency = 1
        valLabel.Text = tostring(defV)
        valLabel.TextColor3 = Color3.new(1,1,1)
        valLabel.TextScaled = true
        valLabel.Font = Enum.Font.Code
        valLabel.Parent = row
    end
    
    local currentVal = defV or 50
    
    tog.MouseButton1Click:Connect(function()
        toggleStates[name:lower():gsub(" ", "")] = not toggleStates[name:lower():gsub(" ", "")]
        local isOn = toggleStates[name:lower():gsub(" ", "")]
        tog.Text = isOn and "ON" or "OFF"
        tog.BackgroundColor3 = isOn and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
        toggleCallback(isOn, currentVal)
    end)
    
    if hasSlider then
        local sliding = false
        sliderFrame.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if not sliding then return end
            local rel = math.clamp((i.Position.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
            currentVal = minV + rel * (maxV - minV)
            sliderBar.Size = UDim2.new(rel, 0, 1, 0)
            valLabel.Text = math.floor(currentVal)
            toggleCallback(toggleStates[name:lower():gsub(" ", "")], currentVal)
        end)
    end
end

