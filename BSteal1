-- Helper to create toggle + slider row
local function createToggleRow(parent, text, hasSlider, minVal, maxVal, defaultVal, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 50)
    row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    row.Parent = parent
    
    local rowCorner = Instance.new("UICorner")
    rowCorner.Parent = row
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextScaled = true
    label.Font = pixelFont
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = row
    
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0.2, 0, 0.7, 0)
    toggleBtn.Position = UDim2.new(0.55, 0, 0.15, 0)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    toggleBtn.Text = "OFF"
    toggleBtn.TextColor3 = Color3.fromRGB(255,255,255)
    toggleBtn.TextScaled = true
    toggleBtn.Font = pixelFont
    toggleBtn.Parent = row
    
    local tCorner = Instance.new("UICorner")
    tCorner.Parent = toggleBtn
    
    local value = defaultVal or 50
    local slider = nil
    local sliderValueLabel = nil
    
    if hasSlider then
        local sliderFrame = Instance.new("Frame")
        sliderFrame.Size = UDim2.new(0.25, 0, 0.4, 0)
        sliderFrame.Position = UDim2.new(0.78, 0, 0.3, 0)
        sliderFrame.BackgroundColor3 = Color3.fromRGB(60,60,60)
        sliderFrame.Parent = row
        
        local sCorner = Instance.new("UICorner")
        sCorner.Parent = sliderFrame
        
        slider = Instance.new("Frame")
        slider.Size = UDim2.new((value - minVal) / (maxVal - minVal), 0, 1, 0)
        slider.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        slider.Parent = sliderFrame
        
        sliderValueLabel = Instance.new("TextLabel")
        sliderValueLabel.Size = UDim2.new(0.2, 0, 1, 0)
        sliderValueLabel.Position = UDim2.new(1.05, 0, 0, 0)
        sliderValueLabel.BackgroundTransparency = 1
        sliderValueLabel.Text = tostring(math.floor(value))
        sliderValueLabel.TextColor3 = Color3.fromRGB(255,255,255)
        sliderValueLabel.TextScaled = true
        sliderValueLabel.Font = pixelFont
        sliderValueLabel.Parent = row
        
        -- Simple slider drag
        local sliderDragging = false
        sliderFrame.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                sliderDragging = true
            end
        end)
        
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                sliderDragging = false
            end
        end)
        
        UserInputService.InputChanged:Connect(function(inp)
            if sliderDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                local mousePos = UserInputService:GetMouseLocation()
                local relPos = (mousePos.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X
                relPos = math.clamp(relPos, 0, 1)
                value = minVal + relPos * (maxVal - minVal)
                slider.Size = UDim2.new(relPos, 0, 1, 0)
                sliderValueLabel.Text = tostring(math.floor(value))
                callback(true, value) -- update
            end
        end)
    end
    
    toggleBtn.MouseButton1Click:Connect(function()
        local state = toggleBtn.Text == "OFF"
        if state then
            toggleBtn.Text = "ON"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        else
            toggleBtn.Text = "OFF"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        end
        callback(state, value)
    end)
    
    return row
end

