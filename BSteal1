-- Вспомогательная функция для безопасного получения таймера базы игрока
local function GetPlayerBaseTimer(player)
    -- Сканирование структуры папки Tycoons/Bases в зависимости от архитектуры ассетов Steal a Brainrot
    local bases = Workspace:FindFirstChild("Bases") or Workspace:FindFirstChild("Tycoons")
    if bases then
        for _, base in pairs(bases:GetChildren()) do
            if base:GetAttribute("Owner") == player.Name or (base:FindFirstChild("Owner") and base.Owner.Value == player) then
                local timerVal = base:FindFirstChild("Timer") or base:FindFirstChild("TimeLeft")
                if timerVal and (timerVal:IsA("ValueBase") or timerVal:IsA("IntValue") or timerVal:IsA("NumberValue")) then
                    return tostring(timerVal.Value) .. "s"
                elseif base:GetAttribute("Timer") then
                    return tostring(base:GetAttribute("Timer")) .. "s"
                end
            end
        end
    end
    return "0s"
end

-- Отрисовка/Обновление ESP игроков
local function ManagePlayerESP(player)
    if player == LocalPlayer then return end
    
    local function applyESP(character)
        if not Flags.EspPlayer then return end
        local root = character:WaitForChild("HumanoidRootPart", 5)
        if not root then return end
        
        if not ESP_Cache[player] then
            ESP_Cache[player] = {}
        end
        
        -- Синий хитбокс (Highlight)
        if not ESP_Cache[player].Highlight or not ESP_Cache[player].Highlight.Parent then
            local highlight = Instance.new("Highlight")
            highlight.FillColor = Color3.fromRGB(0, 100, 255)
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.FillTransparency = 0.5
            highlight.OutlineTransparency = 0
            highlight.Adornee = character
            highlight.Parent = ScreenGui
            ESP_Cache[player].Highlight = highlight
        end
        
        -- Таймер Базы (BillboardGui)
        if not ESP_Cache[player].Billboard or not ESP_Cache[player].Billboard.Parent then
            local bbg = Instance.new("BillboardGui")
            bbg.Size = UDim2.new(0, 100, 0, 30)
            bbg.AlwaysOnTop = true
            bbg.ExtentsOffset = Vector3.new(0, 3, 0)
            bbg.Adornee = root
            bbg.Enabled = Flags.EspLock
            
            local textLabel = Instance.new("TextLabel")
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.BackgroundTransparency = 1
            textLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            textLabel.Font = Theme.Font
            textLabel.TextSize = 14
            textLabel.Text = "Base: --"
            textLabel.Parent = bbg
            
            bbg.Parent = ScreenGui
            ESP_Cache[player].Billboard = bbg
            ESP_Cache[player].TextLabel = textLabel
        end
    end

    if player.Character then
        task.spawn(applyESP, player.Character)
    end
    player.CharacterAdded:Connect(function(char)
        task.spawn(applyESP, char)
    end)
end

for _, p in pairs(Players:GetPlayers()) do ManagePlayerESP(p) end
Players.PlayerAdded:Connect(ManagePlayerESP)

