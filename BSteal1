    local box = Instance.new("BoxHandleAdornment")
    box.Size = root.Size * 1.1
    box.Adornee = root
    box.Color3 = Color3.fromRGB(0, 100, 255)
    box.Transparency = 0.5
    box.AlwaysOnTop = true
    box.ZIndex = 5
    box.Parent = root
    
    return box
end

