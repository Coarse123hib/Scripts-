-- Функция создания Переключателя (Toggle)
local function CreateToggle(parent, text, flagName, callback)
    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.Size = UDim2.new(1, 0, 0, 24)
    ToggleFrame.BackgroundTransparency = 1
    ToggleFrame.Parent = parent
    
    local ToggleLabel = Instance.new("TextLabel")
    ToggleLabel.Size = UDim2.new(1, -35, 1, 0)
    ToggleLabel.BackgroundTransparency = 1
    ToggleLabel.Text = text
    ToggleLabel.TextColor3 = Theme.Text
    ToggleLabel.Font = Theme.Font
    ToggleLabel.TextSize = 12
    ToggleLabel.TextXAlignment = Enum.TextXAlignment.Left
    ToggleLabel.Parent = ToggleFrame
    
    local ToggleButton = Instance.new("TextButton")
    ToggleButton.Size = UDim2.new(0, 30, 0, 16)
    ToggleButton.Position = UDim2.new(1, -30, 0.5, -8)
    ToggleButton.BackgroundColor3 = Flags[flagName] and Theme.ToggleOn or Theme.ToggleOff
    ToggleButton.Text = ""
    ToggleButton.Parent = ToggleFrame
    
    local ButtonElementCorner = Instance.new("UICorner")
    ButtonElementCorner.CornerRadius = UDim.new(0, 3)
    ButtonElementCorner.Parent = ToggleButton
    
    ToggleButton.MouseButton1Click:Connect(function()
        Flags[flagName] = not Flags[flagName]
        TweenService:Create(ToggleButton, TweenInfo.new(0.15), {
            BackgroundColor3 = Flags[flagName] and Theme.ToggleOn or Theme.ToggleOff
        }):Play()
        if callback then callback(Flags[flagName]) end
    end)
end

-- Функция создания Поля Ввода (TextBox)
local function CreateTextBox(parent, placeholder, flagName, minVal, maxVal, callback)
    local InputFrame = Instance.new("Frame")
    InputFrame.Size = UDim2.new(1, 0, 0, 24)
    InputFrame.BackgroundTransparency = 1
    InputFrame.Parent = parent
    
    local Box = Instance.new("TextBox")
    Box.Size = UDim2.new(1, 0, 1, 0)
    Box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Box.PlaceholderText = placeholder .. " (" .. minVal .. "-" .. maxVal .. ")"
    Box.Text = tostring(Flags[flagName])
    Box.TextColor3 = Theme.Text
    Box.PlaceholderColor3 = Color3.fromRGB(120, 120, 120)
    Box.Font = Theme.Font
    Box.TextSize = 11
    Box.ClearTextOnFocus = false
    Box.Parent = InputFrame
    
    local BoxCorner = Instance.new("UICorner")
    BoxCorner.CornerRadius = UDim.new(0, 3)
    BoxCorner.Parent = Box
    
    local BoxStroke = Instance.new("UIStroke")
    BoxStroke.Color = Theme.SectionBackground
    BoxStroke.Thickness = 1
    BoxStroke.Parent = Box
    
    Box.FocusLost:Connect(function(enterPressed)
        local num = tonumber(Box.Text)
        if num then
            num = math.clamp(num, minVal, maxVal)
            Box.Text = tostring(num)
            Flags[flagName] = num
            if callback then callback(num) end
        else
            Box.Text = tostring(Flags[flagName])
        end
    end)
end

