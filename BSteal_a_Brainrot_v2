local function ApplyHighlight(part, color)
    local box = part:FindFirstChild("MornBox") or Instance.new("BoxHandleAdornment")
    box.Name = "MornBox"
    box.Size = part.Size + Vector3.new(0.1, 0.1, 0.1)
    box.AlwaysOnTop = true
    box.ZIndex = 5
    box.Color3 = color
    box.Adornment = part
    box.Transparency = 0.6
    box.Parent = part
    return box
end

local function CreateBillboard(parent, text, offset)
    local bboard = parent:FindFirstChild("MornLabel") or Instance.new("BillboardGui")
    bboard.Name = "MornLabel"
    bboard.Size = UDim2.new(0, 200, 0, 50)
    bboard.AlwaysOnTop = true
    bboard.StudsOffset = offset or Vector3.new(0, 3, 0)
    
    local lbl = bboard:FindFirstChild("Text") or Instance.new("TextLabel")
    lbl.Name = "Text"
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(0, 170, 255)
    lbl.Font = Enum.Font.Code
    lbl.TextSize = 14
    lbl.Text = text
    lbl.Parent = bboard
    
    bboard.Parent = parent
    return lbl
end

