local function CreateTabButton(name)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, 0, 0, 40)
    Btn.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    Btn.TextColor3 = Color3.fromRGB(150, 150, 150)
    Btn.Text = " " .. name
    Btn.Font = Enum.Font.Code
    Btn.TextSize = 14
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    Btn.Parent = NavFrame
    
    Btn.MouseButton1Click:Connect(function()
        State.ActiveTab = name
        for _, child in pairs(ContentFrame:GetChildren()) do
            if child:IsA("ScrollingFrame") then child.Visible = (child.Name == name) end
        end
        for _, b in pairs(NavFrame:GetChildren()) do
            if b:IsA("TextButton") then b.TextColor3 = Color3.fromRGB(150, 150, 150) end
        end
        Btn.TextColor3 = Color3.fromRGB(0, 170, 255)
    end)
end

local Tabs = {}
local function GetTabContainer(name)
    if Tabs[name] then return Tabs[name] end
    local Scroller = Instance.new("ScrollingFrame")
    Scroller.Name = name
    Scroller.Size = UDim2.new(1, 0, 1, 0)
    Scroller.BackgroundTransparency = 1
    Scroller.CanvasSize = UDim2.new(0, 0, 2, 0)
    Scroller.Visible = false
    Scroller.Parent = ContentFrame
    
    local Layout = Instance.new("UIListLayout")
    Layout.Padding = UDim.new(0, 8)
    Layout.Parent = Scroller
    
    local Padding = Instance.new("UIPadding")
    Padding.PaddingTop = UDim.new(0, 10)
    Padding.PaddingLeft = UDim.new(0, 10)
    Padding.Parent = Scroller
    
    Tabs[name] = Scroller
    CreateTabButton(name)
    return Scroller
end

-- Переключатель (Ползунок/Тоггл)
local function AddToggle(tabName, text, stateKey, callback)
    local container = GetTabContainer(tabName)
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0.95, 0, 0, 35)
    Frame.BackgroundTransparency = 1
    Frame.Parent = container
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.7, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.Font = Enum.Font.Code
    Label.TextColor3 = Color3.fromRGB(230, 230, 230)
    Label.TextSize = 14
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Frame
    
    local SliderBg = Instance.new("TextButton")
    SliderBg.Size = UDim2.new(0, 45, 0, 20)
    SliderBg.Position = UDim2.new(0.8, 0, 0.2, 0)
    SliderBg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    SliderBg.Text = ""
    SliderBg.Parent = Frame
    
    local SliderBtn = Instance.new("Frame")
    SliderBtn.Size = UDim2.new(0, 16, 0, 16)
    SliderBtn.Position = UDim2.new(0, 2, 0, 2)
    SliderBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    SliderBtn.Parent = SliderBg
    
    local function updateVisual(val)
        if val then
            TweenService:Create(SliderBtn, TweenInfo.new(0.1), {Position = UDim2.new(0, 27, 0, 2), BackgroundColor3 = Color3.fromRGB(0, 170, 255)}):Play()
        else
            TweenService:Create(SliderBtn, TweenInfo.new(0.1), {Position = UDim2.new(0, 2, 0, 2), BackgroundColor3 = Color3.fromRGB(100, 100, 100)}):Play()
        end
    end
    
    SliderBg.MouseButton1Click:Connect(function()
        State[stateKey] = not State[stateKey]
        updateVisual(State[stateKey])
        if callback then callback(State[stateKey]) end
    end)
end

-- Поле ввода численных значений
local function AddTextBox(tabName, text, min, max, stateKey, callback)
    local container = GetTabContainer(tabName)
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0.95, 0, 0, 35)
    Frame.BackgroundTransparency = 1
    Frame.Parent = container
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.7, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text .. " (" .. tostring(State[stateKey]) .. ")"
    Label.Font = Enum.Font.Code
    Label.TextColor3 = Color3.fromRGB(180, 180, 180)
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Frame
    
    local Input = Instance.new("TextBox")
    Input.Size = UDim2.new(0, 50, 0, 22)
    Input.Position = UDim2.new(0.8, 0, 0.2, 0)
    Input.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Input.TextColor3 = Color3.fromRGB(0, 170, 255)
    Input.Font = Enum.Font.Code
    Input.TextSize = 13
    Input.Text = tostring(State[stateKey])
    Input.Parent = Frame
    
    Input.FocusLost:Connect(function(enterPressed)
        local num = tonumber(Input.Text)
        if num then
            num = math.clamp(num, min, max)
            State[stateKey] = num
            Input.Text = tostring(num)
            Label.Text = text .. " (" .. tostring(num) .. ")"
            if callback then callback(num) end
        else
            Input.Text = tostring(State[stateKey])
        end
    end)
end

